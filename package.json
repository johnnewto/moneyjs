{
  "name": "sfcr-workspace",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "build": "pnpm --filter @sfcr/core build && pnpm --filter @sfcr/web build",
    "dev": "pnpm web:dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "web:dev": "pnpm --filter @sfcr/web dev",
    "web:build": "pnpm --filter @sfcr/web build",
    "web:preview": "pnpm --filter @sfcr/web exec vite preview --port 4173",
    "web:build:pages": "VITE_BASE_PATH=/moneyjs/ pnpm --filter @sfcr/web build",
    "web:preview:pages": "pnpm web:build:pages && node ./scripts/preview-pages.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
