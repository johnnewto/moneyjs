{
  "id": "gl2-pc-notebook",
  "title": "GL2 PC Notebook",
  "metadata": { "version": 1, "template": "gl2-pc" },
  "cells": [
    { "id": "intro", "type": "markdown", "title": "Overview", "source": "This notebook adapts `gl2-pc.Rmd` into executable browser cells. It includes the PC balance-sheet and transactions-flow matrices, the baseline portfolio-choice model, the interest-rate scenario from the article, a deterministic `PCEX1` random-shock section with a stored `Ra` sequence, the `PCEX2` adaptive-expectations variant, and the `PCEX3` interest-sensitive propensity-to-consume extension." },
    {
      "id": "balance-sheet",
      "type": "matrix",
      "title": "PC balance sheet",
      "sourceRunCellId": "baseline-run",
      "columns": ["Households", "Firms", "Government", "Central bank", "Sum"],
      "sectors": ["Households", "Firms", "Government", "Central bank", ""],
      "rows": [
        { "band": "Money", "label": "Money", "values": ["+Hh", "", "", "-Hs", "0"] },
        { "band": "Bills", "label": "Bills", "values": ["+Bh", "", "-Bs", "+Bcb", "0"] },
        { "band": "", "label": "Balance", "values": ["-V", "", "+V", "", "0"] }
      ],
      "description": "Balance-sheet matrix for model PC following the article structure.",
      "note": "Validated against the baseline simulation from the source vignette."
    },
    {
      "id": "transaction-flow",
      "type": "matrix",
      "title": "PC transactions-flow matrix",
      "sourceRunCellId": "baseline-run",
      "columns": ["Households", "Firms", "Government", "CB current", "CB capital"],
      "sectors": ["Households", "Firms", "Government", "Central bank", "Central bank"],
      "rows": [
        { "band": "Consumption", "label": "Consumption", "values": ["-C", "+C", "", "", ""] },
        { "band": "Government", "label": "Govt. expenditures", "values": ["", "+G", "-G", "", ""] },
        { "band": "Income", "label": "Income", "values": ["+Y", "-Y", "", "", ""] },
        { "band": "Interest", "label": "Interest payments", "values": ["+lag(r) * lag(Bh)", "", "-lag(r) * lag(Bs)", "+lag(r) * lag(Bcb)", ""] },
        { "band": "Profits", "label": "CB profits", "values": ["", "", "+lag(r) * lag(Bcb)", "-lag(r) * lag(Bcb)", ""] },
        { "band": "Taxes", "label": "Taxes", "values": ["-TX", "", "+TX", "", ""] },
        { "band": "Money", "label": "Change money", "values": ["-(Hh - lag(Hh))", "", "", "", "+(Hs - lag(Hs))"] },
        { "band": "Bills", "label": "Change bills", "values": ["-(Bh - lag(Bh))", "", "+(Bs - lag(Bs))", "", "-(Bcb - lag(Bcb))"] }
      ],
      "description": "Transactions-flow matrix for model PC following the article structure.",
      "note": "Validated against the baseline simulation from the source vignette."
    },
    { "id": "transaction-flow-sequence", "type": "sequence", "title": "PC transaction flow sequence", "source": { "kind": "matrix", "matrixCellId": "transaction-flow" }, "description": "Sequence view generated from the PC transactions-flow matrix at the selected simulation period." },
    { "id": "equation-dependency-graph", "type": "sequence", "title": "PC  dependency graph", 
    "source": { "kind": "dependency", "modelId": "pc-baseline", "showAccountingStrips": true, "showExogenous": false }, "description": "Dependency view of the pc equations organized by sector strips and accounting bands.", "note": "" },
    {
      "id": "equations",
      "type": "equations",
      "title": "PC model",
      "modelId": "pc-baseline",
      "equations": [
        { "id": "eq-0-Y", "name": "Y", "desc": "National income.", "expression": "C + G", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-1-YD", "name": "YD", "desc": "Disposable income including interest on bills.", "expression": "Y - TX + lag(r) * lag(Bh)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-2-TX", "name": "TX", "desc": "Taxes levied on income and bill interest.", "expression": "theta * (Y + lag(r) * lag(Bh))", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-3-V", "name": "V", "desc": "Household wealth.", "expression": "I(YD - C)", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-4-C", "name": "C", "desc": "Consumption depends on disposable income and lagged wealth.", "expression": "alpha1 * YD + alpha2 * lag(V)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-5-Hh", "name": "Hh", "desc": "Household money holdings.", "expression": "V - Bh", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-6-Hh1", "name": "Hh1", "desc": "Alternative portfolio-choice definition for money holdings.", "expression": "V * ((1 - lambda0) - lambda1 * r + lambda2 * (YD / V))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-7-Bh", "name": "Bh", "desc": "Household bill holdings.", "expression": "V * (lambda0 + lambda1 * r - lambda2 * (YD / V))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-8-Bs", "name": "Bs", "desc": "Government bill supply.", "expression": "I(G + lag(r) * lag(Bs) - TX - lag(r) * lag(Bcb))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-9-Hs", "name": "Hs", "desc": "High-powered money supplied by the central bank.", "expression": "I(d(Bcb))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-10-Bcb", "name": "Bcb", "desc": "Central-bank bill holdings.", "expression": "Bs - Bh", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } }
      ],
      "collapsed": true
    },
    { "id": "solver", "type": "solver", "title": "Solver", "modelId": "pc-baseline", "options": { "periods": 70, "solverMethod": "GAUSS_SEIDEL", "toleranceText": "1e-10", "maxIterations": 200, "defaultInitialValueText": "1e-15", "hiddenLeftVariable": "Hh", "hiddenRightVariable": "Hs", "hiddenToleranceText": "0.00001", "relativeHiddenTolerance": false }, "collapsed": true },
    {
      "id": "externals-equations",
      "type": "externals",
      "title": "Externals",
      "modelId": "pc-baseline",
      "externals": [
        { "id": "ext-0-r", "name": "r", "desc": "Interest rate on bills.", "kind": "constant", "valueText": "0.025", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-1-G", "name": "G", "desc": "Government expenditure.", "kind": "constant", "valueText": "20", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "time": -1 } } },
        { "id": "ext-2-alpha1", "name": "alpha1", "desc": "Propensity to consume out of disposable income.", "kind": "constant", "valueText": "0.6", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "ext-3-alpha2", "name": "alpha2", "desc": "Propensity to consume out of lagged wealth.", "kind": "constant", "valueText": "0.4", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-4-theta", "name": "theta", "desc": "Tax rate.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "ext-5-lambda0", "name": "lambda0", "desc": "Portfolio parameter for bills.", "kind": "constant", "valueText": "0.635", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "ext-6-lambda1", "name": "lambda1", "desc": "Interest sensitivity of bill demand.", "kind": "constant", "valueText": "0.05", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-7-lambda2", "name": "lambda2", "desc": "Income sensitivity of bill demand.", "kind": "constant", "valueText": "0.01", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } }
      ],
      "collapsed": true
    },
    { "id": "initial-values-equations", "type": "initial-values", "title": "Initial values", "modelId": "pc-baseline", "initialValues": [], "collapsed": true },
    { "id": "baseline-run", "type": "run", "title": "Baseline run", "mode": "baseline", "resultKey": "gl2_pc_baseline", "description": "Baseline PC simulation with the hidden-equation condition Hh = Hs.", "sourceModelId": "pc-baseline" },
    { "id": "baseline-chart", "type": "chart", "title": "Baseline headline variables", "sourceRunCellId": "baseline-run", "variables": ["Y", "YD", "C", "V", "Bh", "Hh"], "axisMode": "separate", "axisSnapTolarance": 0.5 },
    { "id": "baseline-table", "type": "table", "title": "Baseline variable summary", "sourceRunCellId": "baseline-run", "variables": ["Y", "YD", "TX", "C", "V", "Bh", "Hh", "Bcb"] },
    { "id": "scenario-1-note", "type": "markdown", "title": "Interest-rate scenario", "source": "This scenario raises the bills rate `r` from `0.025` to `0.035` between periods 5 and 60, matching the first deterministic experiment in the vignette." },
    {
      "id": "scenario-1-run",
      "type": "run",
      "title": "Scenario 1: higher bills rate",
      "mode": "scenario",
      "scenario": {
        "shocks": [
          {
            "rangeInclusive": [5, 60],
            "variables": { "r": { "kind": "constant", "value": 0.035 } }
          }
        ]
      },
      "baselineRunCellId": "baseline-run",
      "periods": 60,
      "resultKey": "gl2_pc_s1",
      "sourceModelId": "pc-baseline"
    },
    { "id": "scenario-1-chart", "type": "chart", "title": "Scenario 1 portfolio adjustment", "sourceRunCellId": "scenario-1-run", "variables": ["Y", "YD", "C", "Bh", "Hh"], "axisMode": "separate", "axisSnapTolarance": 0.5 },
    { "id": "pcex1-note", "type": "markdown", "title": "PCEX1", "source": "This section mirrors the random-shock experiment from `gl2-pc.Rmd`, but uses a fixed stored `Ra` sequence instead of runtime randomness so that browser regressions remain deterministic." },
    {
      "id": "pcex1-equations",
      "type": "equations",
      "title": "PCEX1 fixed-shock model",
      "modelId": "pc-pcex1",
      "equations": [
        { "id": "p1-eq-0-Y", "name": "Y", "desc": "National income.", "expression": "C + G", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "p1-eq-1-YD", "name": "YD", "desc": "Disposable income including lagged bill interest.", "expression": "Y - TX + lag(r) * lag(Bh)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "p1-eq-2-TX", "name": "TX", "desc": "Taxes on income and interest receipts.", "expression": "theta * (Y + lag(r) * lag(Bh))", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "p1-eq-3-V", "name": "V", "desc": "Household wealth.", "expression": "I(YD - C)", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-4-C", "name": "C", "desc": "Consumption based on expected disposable income and lagged wealth.", "expression": "alpha1 * YDE + alpha2 * lag(V)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "p1-eq-5-Hh", "name": "Hh", "desc": "Household money holdings.", "expression": "V - Bh", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-6-Hh1", "name": "Hh1", "desc": "Alternative portfolio-choice definition for money holdings.", "expression": "V * ((1 - lambda0) - lambda1 * r + lambda2 * (YD / V))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-7-Bh", "name": "Bh", "desc": "Realized household bill holdings.", "expression": "Bd", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-8-Bs", "name": "Bs", "desc": "Government bill supply.", "expression": "I(G + lag(r) * lag(Bs) - TX - lag(r) * lag(Bcb))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-9-Hs", "name": "Hs", "desc": "High-powered money supplied by the central bank.", "expression": "I(d(Bcb))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-10-Bcb", "name": "Bcb", "desc": "Central-bank bill holdings.", "expression": "Bs - Bh", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-11-Hd", "name": "Hd", "desc": "Desired household money holdings.", "expression": "VE - Bd", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-12-VE", "name": "VE", "desc": "Expected household wealth.", "expression": "lag(V) + (YDE - C) * dt", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-13-Bd", "name": "Bd", "desc": "Desired household bill holdings.", "expression": "VE * (lambda0 + lambda1 * r - lambda2 * (YDE / VE))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "p1-eq-14-YDE", "name": "YDE", "desc": "Expected disposable income with the fixed shock sequence.", "expression": "YD * (1 + Ra)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } }
      ],
      "collapsed": true
    },
    { "id": "pcex1-solver", "type": "solver", "title": "Solver", "modelId": "pc-pcex1", "options": { "periods": 60, "solverMethod": "GAUSS_SEIDEL", "toleranceText": "1e-10", "maxIterations": 200, "defaultInitialValueText": "1e-15", "hiddenLeftVariable": "Hh", "hiddenRightVariable": "Hs", "hiddenToleranceText": "0.00001", "relativeHiddenTolerance": false }, "collapsed": true },
    {
      "id": "pcex1-externals",
      "type": "externals",
      "title": "Externals",
      "modelId": "pc-pcex1",
      "externals": [
        { "id": "p1-ext-0-r", "name": "r", "desc": "Interest rate on bills.", "kind": "constant", "valueText": "0.025", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "p1-ext-1-G", "name": "G", "desc": "Government expenditure.", "kind": "constant", "valueText": "20", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "time": -1 } } },
        { "id": "p1-ext-2-alpha1", "name": "alpha1", "desc": "Propensity to consume out of expected disposable income.", "kind": "constant", "valueText": "0.6", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "p1-ext-3-alpha2", "name": "alpha2", "desc": "Propensity to consume out of lagged wealth.", "kind": "constant", "valueText": "0.4", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "p1-ext-4-theta", "name": "theta", "desc": "Tax rate.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "p1-ext-5-lambda0", "name": "lambda0", "desc": "Portfolio parameter for bills.", "kind": "constant", "valueText": "0.635", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "p1-ext-6-lambda1", "name": "lambda1", "desc": "Interest sensitivity of bill demand.", "kind": "constant", "valueText": "0.05", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "p1-ext-7-lambda2", "name": "lambda2", "desc": "Income sensitivity of bill demand.", "kind": "constant", "valueText": "0.01", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "p1-ext-8-Ra", "name": "Ra", "desc": "Fixed shock sequence for expected disposable income.", "kind": "series", "valueText": "-0.028023782328, -0.011508874474, 0.077935415707, 0.003525419571, 0.006464386758, 0.085753249344, 0.023045810299, -0.06325306173, -0.034342642595, -0.022283098505, 0.061204089872, 0.017990691353, 0.02003857253, 0.005534135797, -0.027792056738, 0.08934565684, 0.024892523911, -0.098330857831, 0.035067795078, -0.023639570386, -0.053391185299, -0.010898745733, -0.051300222415, -0.036444561465, -0.031251963392, -0.084334665537, 0.041889352225, 0.007668655892, -0.056906846851, 0.062690746053, 0.021323211074, -0.01475357415, 0.044756283052, 0.043906674377, 0.041079054082, 0.034432012705, 0.027695882677, -0.003095585529, -0.015298133187, -0.019023550051, -0.034735348946, -0.010395863901, -0.063269817578, 0.108447798267, 0.060398099915, -0.05615542916, -0.020144241765, -0.023332767681, 0.038998255917, -0.004168453324, 0.0126659257, -0.001427337767, -0.002143522865, 0.068430114201, -0.011288549283, 0.075823530221, -0.077437640212, 0.029230687482, 0.006192712192, 0.010797078437", "unitMeta": { "stockFlow": "aux", "signature": {} } }
      ],
      "collapsed": true
    },
    { "id": "pcex1-initial-values", "type": "initial-values", "title": "Initial values", "modelId": "pc-pcex1", "initialValues": [], "collapsed": true },
    { "id": "pcex1-baseline-run", "type": "run", "title": "PCEX1 baseline run", "mode": "baseline", "resultKey": "gl2_pc_pcex1_baseline", "description": "PCEX1 with a stored `Ra` shock series and the hidden-equation condition Hh = Hs.", "sourceModelId": "pc-pcex1" },
    { "id": "pcex1-baseline-chart", "type": "chart", "title": "PCEX1 stocks and desired holdings", "sourceRunCellId": "pcex1-baseline-run", "variables": ["Hh", "Hd", "Bh", "Bd", "YDE"], "axisMode": "separate", "axisSnapTolarance": 0.5 },
    { "id": "pcex1-baseline-table", "type": "table", "title": "PCEX1 variable summary", "sourceRunCellId": "pcex1-baseline-run", "variables": ["Y", "YD", "YDE", "C", "V", "Hh", "Hd", "Bh", "Bd"] },
    { "id": "adaptive-note", "type": "markdown", "title": "Adaptive expectations", "source": "The next model follows the adaptive-expectations section of `gl2-pc.Rmd`. Expected disposable income is set to `lag(YD)`, and the wealth-allocation equations are rewritten in terms of desired bills `Bd` and expected wealth `VE`." },
    {
      "id": "adaptive-equations",
      "type": "equations",
      "title": "PCEX2 adaptive model",
      "modelId": "pc-adaptive",
      "equations": [
        { "id": "ad-eq-0-Y", "name": "Y", "desc": "National income.", "expression": "C + G", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "ad-eq-1-YD", "name": "YD", "desc": "Disposable income including lagged bill interest.", "expression": "Y - TX + lag(r) * lag(Bh)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "ad-eq-2-TX", "name": "TX", "desc": "Taxes on income and interest receipts.", "expression": "theta * (Y + lag(r) * lag(Bh))", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "ad-eq-3-V", "name": "V", "desc": "Household wealth.", "expression": "I(YD - C)", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-4-C", "name": "C", "desc": "Consumption based on expected disposable income and lagged wealth.", "expression": "alpha1 * YDE + alpha2 * lag(V)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "ad-eq-5-Hh", "name": "Hh", "desc": "Household money holdings.", "expression": "V - Bh", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-6-Hh1", "name": "Hh1", "desc": "Alternative portfolio-choice definition for money holdings.", "expression": "V * ((1 - lambda0) - lambda1 * r + lambda2 * (YD / V))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-7-Bh", "name": "Bh", "desc": "Realized household bill holdings.", "expression": "Bd", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-8-Bs", "name": "Bs", "desc": "Government bill supply.", "expression": "I(G + lag(r) * lag(Bs) - TX - lag(r) * lag(Bcb))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-9-Hs", "name": "Hs", "desc": "High-powered money supplied by the central bank.", "expression": "I(Bcb - lag(Bcb))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-10-Bcb", "name": "Bcb", "desc": "Central-bank bill holdings.", "expression": "Bs - Bh", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-11-Hd", "name": "Hd", "desc": "Desired household money holdings.", "expression": "VE - Bd", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-12-VE", "name": "VE", "desc": "Expected household wealth.", "expression": "lag(V) + (YDE - C) * dt", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-13-Bd", "name": "Bd", "desc": "Desired household bill holdings.", "expression": "VE * (lambda0 + lambda1 * r - lambda2 * (YDE / VE))", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "ad-eq-14-YDE", "name": "YDE", "desc": "Expected disposable income formed adaptively.", "expression": "lag(YD)", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } }
      ],
      "collapsed": true
    },
    { "id": "adaptive-solver", "type": "solver", "title": "Solver", "modelId": "pc-adaptive", "options": { "periods": 60, "solverMethod": "GAUSS_SEIDEL", "toleranceText": "1e-10", "maxIterations": 200, "defaultInitialValueText": "1e-15", "hiddenLeftVariable": "", "hiddenRightVariable": "", "hiddenToleranceText": "0.00001", "relativeHiddenTolerance": false }, "collapsed": true },
    {
      "id": "adaptive-externals",
      "type": "externals",
      "title": "Externals",
      "modelId": "pc-adaptive",
      "externals": [
        { "id": "ad-ext-0-r", "name": "r", "desc": "Interest rate on bills.", "kind": "constant", "valueText": "0.025", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ad-ext-1-G", "name": "G", "desc": "Government expenditure.", "kind": "constant", "valueText": "20", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "time": -1 } } },
        { "id": "ad-ext-2-alpha1", "name": "alpha1", "desc": "Propensity to consume out of expected disposable income.", "kind": "constant", "valueText": "0.6", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "ad-ext-3-alpha2", "name": "alpha2", "desc": "Propensity to consume out of lagged wealth.", "kind": "constant", "valueText": "0.4", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ad-ext-4-theta", "name": "theta", "desc": "Tax rate.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux", "signature": {} } },
        { "id": "ad-ext-5-lambda0", "name": "lambda0", "desc": "Portfolio parameter for bills.", "kind": "constant", "valueText": "0.635", "unitMeta": { "stockFlow": "aux", "signature": {} } },
