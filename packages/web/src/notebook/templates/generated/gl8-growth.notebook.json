        { "id": "eq-122-ADDl", "name": "ADDl", "desc": "Spread between interest rate on loans and rate on deposits", "expression": "(Fb^T - R_b[-1] * B_bd[-1] + r_m[-1] * (Ms[-1] - (1 - npl^e) * L_fs[-1] - L_hs[-1])) / ((1 - npl^e) * L_fs[-1] + L_hs[-1])" },
