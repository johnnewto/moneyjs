{
  "id": "bmw-notebook",
  "title": "BMW Browser Notebook",
  "metadata": { "version": 1, "template": "bmw" },
  "cells": [
    { "id": "intro", "type": "markdown", "title": "Overview", "source": "This browser notebook adapts the BMW vignette into executable model, run, and chart cells. It focuses on a Newton baseline and two scenario comparisons." },
    {
      "id": "balance-sheet",
      "type": "matrix",
      "title": "BMW balance sheet",
      "sourceRunCellId": "baseline-newton",
      "accountingKind": "balance-sheet",
      "columns": ["Households", "Production firms", "Banks", "Sum"],
      "sectors": ["Households", "Firms", "Banks", ""],
      "rows": [
        { "band": "Deposits", "label": "Money deposits", "values": ["+Mh", "", "-Ms", "0"] },
        { "band": "Loans", "label": "Loans", "values": ["", "-Ld", "+Ls", "0"] },
        { "band": "Investment", "label": "Fixed capital", "values": ["", "+K", "", "+K"] },
        { "band": "Balance", "label": "Balance (net worth)", "values": ["-Vh", "-V", "0", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["0", "0", "0", "0"] }
      ],
      "description": "Balance-sheet matrix for the BMW model, following the sfcr article presentation.",
      "note": "Source structure adapted from the sfcr BMW article balance-sheet display."
    },
    {
      "id": "transaction-flow",
      "type": "matrix",
      "title": "BMW transactions-flow matrix",
      "sourceRunCellId": "baseline-newton",
      "accountingKind": "transaction-flow",
      "columns": ["Households", "Firms_current", "Firms_capital", "Banks_current", "Banks_capital", "Sum"],
      "sectors": ["Households", "Firms", "Firms", "Banks", "Banks", ""],
      "rows": [
        { "band": "Consumption", "label": "Consumption", "values": ["-Cs", "+Cd", "", "", "", "0"] },
        { "band": "Investment", "label": "Investment", "values": ["", "+Is", "-Id", "", "", "0"] },
        { "band": "Wages", "label": "Wages", "values": ["+WBs", "-WBd", "", "", "", "0"] },
        { "band": "Depreciation", "label": "Depreciation", "values": ["", "-AF", "+AF", "", "", "0"] },
        { "band": "Loans", "label": "Interest loans", "values": ["", "-rl[-1]*Ld[-1]", "", "+rl[-1]*Ls[-1]", "", "0"] },
        { "band": "Deposits", "label": "Interest on deposits", "values": ["+rm[-1]*Mh[-1]", "", "", "-rm[-1]*Ms[-1]", "", "0"] },
        { "band": "Loans", "label": "Ch. loans", "values": ["", "", "+d(Ld)", "", "-d(Ls)", "0"] },
        { "band": "Deposits", "label": "Ch. deposits", "values": ["-d(Mh)", "", "", "", "+d(Ms)", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["0", "0", "0", "0", "0", "0"] }
      ],
      "description": "Transactions-flow matrix for the BMW model, shown in the same accounting style as the sfcr article.",
      "note": "Signs and row structure follow the BMW transactions-flow matrix in the sfcr article."
    },
    {
      "id": "account-transactions",
      "type": "matrix",
      "title": "BMW account transactions",
      "sourceRunCellId": "baseline-newton",
      "accountingKind": "account-transactions",
      "columns": ["Deposits (Mh)", "Net_Worth (Vh)", "Deposits (Mf)", "Capital", "Loans", "Net_Worth (Vf)", "Firm.Loans", "HH.Deposits", "Firm.Deposits", "Net_Worth (Vb)", "Sum"],
      "columnBadges": ["asset", "equity", "asset", "asset", "liability", "equity", "asset", "liability", "liability", "equity", ""],
      "sectors": ["Households(HH)", "Households(HH)", "Firms", "Firms", "Firms", "Firms", "Banks", "Banks", "Banks", "Banks", ""],
      "rows": [
        { "band": "Wages", "label": "Wages", "values": ["WBd", "WBd", "-WBd", "", "", "-WBd", "", "-WBd", "+WBd", "", "0"] },
        { "band": "Consumption", "label": "Consumption", "values": ["-Cs", "-Cs", "+Cd", "", "", "+Cd", "", "+Cs", "-Cd", "", "0"] },
        { "band": "Investment", "label": "Investment", "values": ["", "", "+Is", "-Is", "", "", "", "", "", "", "0"] },
        { "band": "Depreciation", "label": "Depreciation", "values": ["", "", "-AF", "+AF", "", "", "", "", "", "", "0"] },
        { "band": "Loans", "label": "Interest loans", "values": ["", "", "-rl'*Ld'", "", "", "-rl'*Ld'", "", "", "+rl'*Ld'", "rl[-1]*Ls[-1]", "0"] },
        { "band": "Deposits", "label": "Interest on deposits", "values": ["+rm'*Mh'", "+rm'*Mh'", "", "", "", "", "", "-rm'•Mh'", "", "-rm[-1]*Ms[-1]", "0"] },
        { "band": "Loans", "label": "Ch. loans", "values": ["", "", "d(Ld)", "", "-d(Ls)", "+d(Ld)-d(Ls)", "+d(Ls)", "", "-d(Ld)", "", "0"] },
        { "band": "Deposits", "label": "Ch. deposits", "values": ["", "", "", "", "", "+d(K)", "", "", "", "", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["Mh", "Vh", "Mf", "", "Ls", "", "", "", "", "", "0"] }
      ],
      "collapsed": false,
      "description": "Account-level transaction matrix for BMW with hierarchical sector and account columns.",
      "note": "Columns group balance-sheet accounts by sector. Use Expand all / Collapse all or click sector headers to show or hide account columns."
    },
    { "id": "transaction-flow-sequence", "type": "sequence", "title": "BMW transaction flow sequence", "source": { "kind": "matrix", "matrixCellId": "transaction-flow" }, "participantColumnOrder": ["Households", "Firms_current", "Firms_capital", "Banks_current", "Banks_capital"], "description": "Canvas-rendered sequence view generated from the transactions-flow matrix at the selected simulation period.", "note": "Use Reset and Next step to manually reveal flows in order." },
    {
      "id": "equations-newton",
      "type": "equations",
      "title": "BMW model",
      "modelId": "equations-newton",
      "equations": [
        { "id": "eq-comment-0-Equalize-supply-to-demand", "kind": "comment", "text": "Equalize supply to demand." },
        { "id": "eq-1-Cs", "name": "Cs", "desc": "Consumption goods supply", "expression": "Cd", "role": "definition", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-comment-2-Production-Firms", "kind": "comment", "text": "Production Firms" },
        { "id": "eq-3-Is", "name": "Is", "desc": "Supply of investment goods", "expression": "Id", "role": "definition", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-5-Y", "name": "Y", "desc": "Income = GDP", "expression": "Cs + Is", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-6-WBd", "name": "WBd", "desc": "Wage bill - demand", "expression": "Y - lag(rl) * lag(Ld) - AF", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-7-AF", "name": "AF", "desc": "Amortization funds", "expression": "delta * lag(K)", "role": "definition", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-18-DA", "name": "DA", "desc": "Depreciation allowance", "expression": "delta * lag(K)", "role": "definition", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-8-Ld", "name": "Ld", "desc": "Demand for bank loans", "expression": "lag(Ld) + (Id - AF) * dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-19-KT", "name": "KT", "desc": "Target stock of capital", "expression": "kappa * lag(Y)", "role": "target", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-17-K", "name": "K", "desc": "Stock of capital", "expression": "K' + (Id - DA) • dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-20-Id", "name": "Id", "desc": "Demand for investment goods", "expression": "gamma * (KT - lag(K)) + DA", "role": "behavioral", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-mf", "name": "Mf", "desc": "Stock accumulation from Firms.Deposits (Mf)", "expression": "Mf' + Firms.Deposits * dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-comment-13-Wage-bill", "kind": "comment", "text": "Wage bill" },
        { "id": "eq-14-Ns", "name": "Ns", "desc": "Supply of labor", "expression": "Nd", "role": "definition", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-13-WBs", "name": "WBs", "desc": "Wage bill - supply", "expression": "W * Ns", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-14-Nd", "name": "Nd", "desc": "Demand for labor", "expression": "Y / pr", "role": "definition", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-15-W", "name": "W", "desc": "Wage rate", "expression": "WBd / Nd", "role": "definition", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-comment-18-Households", "kind": "comment", "text": "Households." },
        { "id": "eq-9-YD", "name": "YD", "desc": "Disposable income of households", "expression": "WBs + lag(rm) * lag(Mh)", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-16-Cd", "name": "Cd", "desc": "Consumption goods demand by households", "expression": "alpha0 + alpha1 * YD + alpha2 * lag(Mh)", "role": "behavioral", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-10-Mh", "name": "Mh", "desc": "Stock accumulation from Households.Deposits (Mh)", "expression": "Mh' + Households.Deposits * dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-vh", "name": "Vh", "desc": "Stock accumulation from Households.Net_Worth (Vh)", "expression": "Vh' + Households.Net_Worth * dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-comment-23-Banks", "kind": "comment", "text": "Banks" },
        { "id": "eq-12-rm", "name": "rm", "desc": "Rate of interest on bank deposits", "expression": "rl", "role": "definition", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "eq-25-Ls", "name": "Ls", "desc": "Supply of bank loans", "expression": "lag(Ls) + d(Ld) * dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-11-Ms", "name": "Ms", "desc": "Supply of bank deposits", "expression": "lag(Ms) + d(Ls) * dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } }
      ],
      "collapsed": false
    },
    { "id": "sequence-cld", "type": "sequence", "title": "Causal loop diagram", "source": { "kind": "cld", "modelId": "equations-newton" }, "collapsed": false },
    { "id": "solver-newton", "type": "solver", "title": "Solver options", "modelId": "equations-newton", "options": { "solverMethod": "NEWTON", "toleranceText": "1e-10", "maxIterations": 100, "defaultInitialValueText": "1e-15", "hiddenLeftVariable": "Ms", "hiddenRightVariable": "Mh", "hiddenToleranceText": "0.00001", "relativeHiddenTolerance": false }, "collapsed": true },
    {
      "id": "externals-equations-newton",
      "type": "externals",
      "title": "Externals",
      "modelId": "equations-newton",
      "externals": [
        { "id": "ext-0-rl", "name": "rl", "desc": "Rate of interest on bank loans, set exogenously", "kind": "constant", "valueText": "0.025", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-1-alpha0", "name": "alpha0", "desc": "Exogenous component in consumption", "kind": "constant", "valueText": "20", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "time": -1 } } },
        { "id": "ext-2-alpha1", "name": "alpha1", "desc": "Propensity to consume out of income", "kind": "constant", "valueText": "0.75", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-3-alpha2", "name": "alpha2", "desc": "Propensity to consume out of wealth", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-4-delta", "name": "delta", "desc": "Depreciation rate", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-5-gamma", "name": "gamma", "desc": "Speed of adjustment of capital to its target value", "kind": "constant", "valueText": "0.15", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-6-kappa", "name": "kappa", "desc": "Capital-output ratio", "kind": "constant", "valueText": "1", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-7-pr", "name": "pr", "desc": "Labor productivity", "kind": "constant", "valueText": "1", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } }
      ],
      "collapsed": true
    },
    { "id": "initial-values-equations-newton", "type": "initial-values", "title": "Initial values", "modelId": "equations-newton", "initialValues": [], "collapsed": true },
    { "id": "baseline-newton", "type": "run", "title": "Baseline run with Newton", "note": "This Newton baseline provides the reference path for the BMW scenarios.", "description": "Run the baseline for 50 periods using the Newton solver to generate the reference path for the BMW scenarios.", "mode": "baseline", "periods": 50, "resultKey": "bmw_newton", "sourceModelId": "equations-newton" },
    { "id": "baseline-chart", "type": "chart", "title": "Baseline headline variables", "description": "Chart of key variables in the baseline run to show the model's dynamic behavior over time.", "note": "This chart shows the time paths of selected variables in the baseline run, which serves as the reference for the scenario comparisons.", "sourceRunCellId": "baseline-newton", "variables": ["Y", "Cd", "Mh", "W"], "axisMode": "separate", "axisSnapTolarance": 0.1, "niceScale": true },
    { "id": "baseline-table", "type": "table", "title": "Baseline variable summary", "note": "Table of selected variables for the baseline run, showing values at each period.", "description": "This table shows the values of key variables in the baseline run across all periods.", "sourceRunCellId": "baseline-newton", "variables": ["Y", "Cd", "Id", "K", "Mh", "W"] },
    { "id": "scenario-1-note", "type": "markdown", "title": "Scenario 1", "source": "Scenario 1 increases autonomous consumption expenditure by raising alpha0 from period 5 to period 50." },
    {
      "id": "scenario-1-run",
      "type": "run",
      "title": "Scenario 1: autonomous consumption shock",
      "note": "This scenario applies a shock to autonomous consumption by increasing alpha0 for a period of time",
      "description": "allowing us to see the effect on the economy compared to the baseline.",
      "mode": "scenario",
      "scenario": {
        "shocks": [
          { "variables": { "alpha0": { "kind": "constant", "value": 30 } }, "startPeriodInclusive": 5, "endPeriodInclusive": 50 }
        ]
      },
      "baselineRunCellId": "baseline-newton",
      "periods": 50,
      "resultKey": "bmw_s1",
      "sourceModelId": "equations-newton",
      "baselineStartPeriod": 40
    },
    { "id": "scenario-1-chart", "type": "chart", "title": "Scenario 1 consumption and income", "sourceRunCellId": "scenario-1-run", "variables": ["Cd", "YD", "Id", "AF"], "sharedRange": { "includeZero": true }, "axisMode": "separate", "axisSnapTolarance": 0.1, "niceScale": true },
    {
      "id": "scenario-2-run",
      "type": "run",
      "title": "Scenario 2: propensity-to-save shock",
      "description": "Scenario 2 lowers alpha1 from period 5 to period 50 to examine the effect of a higher propensity to save.",
      "mode": "scenario",
      "scenario": {
        "shocks": [
          { "variables": { "alpha1": { "kind": "constant", "value": 0.7 } }, "startPeriodInclusive": 5, "endPeriodInclusive": 50 }
        ]
      },
      "baselineRunCellId": "baseline-newton",
      "periods": 50,
      "resultKey": "bmw_s2",
      "sourceModelId": "equations-newton"
    },
    { "id": "scenario-2-chart", "type": "chart", "title": "Scenario 2 headline variables", "sourceRunCellId": "scenario-2-run", "variables": ["Cd", "YD", "W"], "sharedRange": { "includeZero": true } },
    { "id": "equation-dependency-graph", "type": "sequence", "title": "BMW equation dependency graph", "source": { "kind": "dependency", "modelId": "equations-newton", "showAccountingStrips": true, "showExogenous": false }, "description": "Dependency view of the BMW equations organized by sector strips and accounting bands.", "note": "Use this alongside the transaction-flow sequence to compare accounting flows with equation structure.", "collapsed": true }
  ]
}
