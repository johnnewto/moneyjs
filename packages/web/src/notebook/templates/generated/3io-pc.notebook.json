{
  "id": "3io-pc-notebook",
  "title": "Model 3IO-PC Notebook",
  "metadata": { "version": 1, "template": "3io-pc" },
  "cells": [
    { "id": "intro", "type": "markdown", "title": "Overview", "source": "This notebook ports Marco Veronese Passarella's Model 3IO-PC from the Florence 2025 keynote (`references/keynote_speech_Florence/0_3IO-PC-Model.R`). It extends Godley and Lavoie Model PC with a three-industry input-output structure, endogenous reproduction prices, and inflation-tax consumption without monetary illusion." },
    {
      "id": "balance-sheet",
      "type": "matrix",
      "title": "3IO-PC balance sheet",
      "sourceRunCellId": "baseline-run",
      "accountingKind": "balance-sheet",
      "columns": ["Households", "Firms", "Central bank", "Government", "Sum"],
      "sectors": ["Households", "Firms", "Central bank", "Government", ""],
      "rows": [
        { "band": "Cash", "label": "Cash (money)", "values": ["+h_h", "", "-h_s", "", "0"] },
        { "band": "Bills", "label": "Bills", "values": ["+b_h", "", "+b_cb", "-b_s", "0"] },
        { "band": "Wealth", "label": "Wealth", "values": ["-v", "", "", "+b_s", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["0", "0", "0", "0", "0"] }
      ],
      "description": "Balance-sheet matrix for the 3IO-PC macro structure.",
      "note": "Validated against the baseline simulation in the Florence R fixture."
    },
    {
      "id": "transaction-flow",
      "type": "matrix",
      "title": "3IO-PC transactions-flow matrix",
      "sourceRunCellId": "baseline-run",
      "accountingKind": "transaction-flow",
      "columns": ["Households", "Firms", "Central bank", "Government", "Sum"],
      "sectors": ["Households", "Firms", "Central bank", "Government", ""],
      "rows": [
        { "band": "Consumption", "label": "Consumption", "values": ["-cons * p_c", "+cons * p_c", "", "", "0"] },
        { "band": "Government", "label": "Government expenditure", "values": ["", "+g * p_g", "", "-g * p_g", "0"] },
        { "band": "Income", "label": "GDP (income)", "values": ["+y", "-y", "", "", "0"] },
        { "band": "Interest", "label": "Interest payments", "values": ["+lag(r) * lag(b_h)", "", "+lag(r) * lag(b_cb)", "-lag(r) * lag(b_s)", "0"] },
        { "band": "Profits", "label": "CB profit", "values": ["", "", "-lag(r) * lag(b_cb)", "+lag(r) * lag(b_cb)", "0"] },
        { "band": "Taxes", "label": "Taxes", "values": ["-t", "", "", "+t", "0"] },
        { "band": "Cash", "label": "Change in cash", "values": ["-d(h_h)", "", "+d(h_s)", "", "0"] },
        { "band": "Bills", "label": "Change in bills", "values": ["-d(b_h)", "", "-d(b_cb)", "+d(b_s)", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["0", "0", "0", "0", "0"] }
      ],
      "description": "Transactions-flow matrix for the 3IO-PC macro structure.",
      "note": "Validated against the baseline simulation in the Florence R fixture."
    },
    { "id": "transaction-flow-sequence", "type": "sequence", "title": "3IO-PC transaction flow sequence", "source": { "kind": "matrix", "matrixCellId": "transaction-flow" }, "description": "Sequence view generated from the transactions-flow matrix at the selected simulation period." },
    {
      "id": "equations",
      "type": "equations",
      "title": "3IO-PC model",
      "modelId": "3io-pc",
      "equations": [
        { "id": "eq-0-d1", "name": "d1", "desc": "Final demand for agriculture.", "expression": "beta1_c * cons + beta1_g * g", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-1-d2", "name": "d2", "desc": "Final demand for manufacturing.", "expression": "beta2_c * cons + beta2_g * g", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-2-d3", "name": "d3", "desc": "Final demand for services.", "expression": "beta3_c * cons + beta3_g * g", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-3-x1", "name": "x1", "desc": "Gross output in agriculture.", "expression": "a11 * x1 + a12 * x2 + a13 * x3 + d1", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-4-x2", "name": "x2", "desc": "Gross output in manufacturing.", "expression": "a21 * x1 + a22 * x2 + a23 * x3 + d2", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-5-x3", "name": "x3", "desc": "Gross output in services.", "expression": "a31 * x1 + a32 * x2 + a33 * x3 + d3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-6-y", "name": "y", "desc": "Nominal GDP from final demands.", "expression": "p1 * d1 + p2 * d2 + p3 * d3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-7-nd1", "name": "nd1", "desc": "Nominal final demand for agriculture.", "expression": "p1 * d1", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-8-nd2", "name": "nd2", "desc": "Nominal final demand for manufacturing.", "expression": "p2 * d2", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-9-nd3", "name": "nd3", "desc": "Nominal final demand for services.", "expression": "p3 * d3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-10-nx1", "name": "nx1", "desc": "Nominal gross output in agriculture.", "expression": "p1 * x1", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-11-nx2", "name": "nx2", "desc": "Nominal gross output in manufacturing.", "expression": "p2 * x2", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-12-nx3", "name": "nx3", "desc": "Nominal gross output in services.", "expression": "p3 * x3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-13-p1", "name": "p1", "desc": "Unit price in agriculture.", "expression": "(w / pr1) + (p1 * a11 + p2 * a21 + p3 * a31) * (1 + mu)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-14-p2", "name": "p2", "desc": "Unit price in manufacturing.", "expression": "(w / pr2) + (p1 * a12 + p2 * a22 + p3 * a32) * (1 + mu)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-15-p3", "name": "p3", "desc": "Unit price in services.", "expression": "(w / pr3) + (p1 * a13 + p2 * a23 + p3 * a33) * (1 + mu)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-16-p_c", "name": "p_c", "desc": "Consumer price index.", "expression": "p1 * beta1_c + p2 * beta2_c + p3 * beta3_c", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-17-p_g", "name": "p_g", "desc": "Government purchase price index.", "expression": "p1 * beta1_g + p2 * beta2_g + p3 * beta3_g", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-18-yd", "name": "yd", "desc": "Household disposable income.", "expression": "y - t + lag(r) * lag(b_h)", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-19-v", "name": "v", "desc": "Household wealth.", "expression": "I(yd - p_c * cons)", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-20-infl", "name": "infl", "desc": "Inflation tax on lagged wealth.", "expression": "(d(p_c) / p_c') * (v' / p_c)", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-21-cons", "name": "cons", "desc": "Real consumption without monetary illusion.", "expression": "alpha1 * ((yd / p_c) - infl) + alpha2 * lag(v) / p_c", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-22-alpha1", "name": "alpha1", "desc": "Endogenous propensity to consume out of income.", "expression": "alpha10 - alpha11 * lag(r)", "role": "identity", "unitMeta": { "stockFlow": "aux" } },
        { "id": "eq-23-h_h", "name": "h_h", "desc": "Household cash holdings.", "expression": "v - b_h", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-24-b_h", "name": "b_h", "desc": "Household bill holdings.", "expression": "v * (lambda0 + lambda1 * r - lambda2 * (yd / v))", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-25-t", "name": "t", "desc": "Income and interest taxes.", "expression": "theta * (y + lag(r) * lag(b_h))", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-26-b_s", "name": "b_s", "desc": "Government bill supply.", "expression": "I(p_g * g + lag(r) * lag(b_s) - t - lag(r) * lag(b_cb))", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-27-h_s", "name": "h_s", "desc": "High-powered money supply.", "expression": "I(b_cb - lag(b_cb))", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-28-b_cb", "name": "b_cb", "desc": "Central-bank bill holdings.", "expression": "b_s - b_h", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } }
      ],
      "collapsed": false
    },
    { "id": "solver", "type": "solver", "title": "Solver", "modelId": "3io-pc", "options": { "solverMethod": "GAUSS_SEIDEL", "toleranceText": "1e-10", "maxIterations": 200, "defaultInitialValueText": "0", "hiddenLeftVariable": "h_h", "hiddenRightVariable": "h_s", "hiddenToleranceText": "1e-6", "relativeHiddenTolerance": false }, "collapsed": true },
    {
      "id": "externals-equations",
      "type": "externals",
      "title": "Externals",
      "modelId": "3io-pc",
      "externals": [
        { "id": "ext-0-r", "name": "r", "desc": "Interest rate on government bills.", "kind": "constant", "valueText": "0.025", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-1-g", "name": "g", "desc": "Real government expenditure.", "kind": "constant", "valueText": "20", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "ext-2-alpha10", "name": "alpha10", "desc": "Autonomous propensity to consume out of income.", "kind": "constant", "valueText": "0.8", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-3-alpha11", "name": "alpha11", "desc": "Interest-rate elasticity of consumption propensity.", "kind": "constant", "valueText": "8", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-4-alpha2", "name": "alpha2", "desc": "Propensity to consume out of lagged wealth.", "kind": "constant", "valueText": "0.4", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-5-w", "name": "w", "desc": "Uniform wage rate.", "kind": "constant", "valueText": "0.4", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "ext-6-mu", "name": "mu", "desc": "Uniform markup.", "kind": "constant", "valueText": "0.875", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-7-pr1", "name": "pr1", "desc": "Labour productivity in agriculture.", "kind": "constant", "valueText": "3.5", "unitMeta": { "stockFlow": "aux", "signature": { "items": 1, "time": -1 } } },
        { "id": "ext-8-pr2", "name": "pr2", "desc": "Labour productivity in manufacturing.", "kind": "constant", "valueText": "5", "unitMeta": { "stockFlow": "aux", "signature": { "items": 1, "time": -1 } } },
        { "id": "ext-9-pr3", "name": "pr3", "desc": "Labour productivity in services.", "kind": "constant", "valueText": "2.2", "unitMeta": { "stockFlow": "aux", "signature": { "items": 1, "time": -1 } } },
        { "id": "ext-10-lambda0", "name": "lambda0", "desc": "Autonomous portfolio share of bills.", "kind": "constant", "valueText": "0.635", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-11-lambda1", "name": "lambda1", "desc": "Interest elasticity of bill demand.", "kind": "constant", "valueText": "5", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-12-lambda2", "name": "lambda2", "desc": "Income elasticity of bill demand.", "kind": "constant", "valueText": "0.01", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-13-theta", "name": "theta", "desc": "Tax rate on income and interest.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-14-beta1_c", "name": "beta1_c", "desc": "Consumption share of agriculture output.", "kind": "constant", "valueText": "0.15", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-15-beta2_c", "name": "beta2_c", "desc": "Consumption share of manufacturing output.", "kind": "constant", "valueText": "0.35", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-16-beta3_c", "name": "beta3_c", "desc": "Consumption share of services output.", "kind": "constant", "valueText": "0.5", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-17-beta1_g", "name": "beta1_g", "desc": "Government spending share of agriculture output.", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-18-beta2_g", "name": "beta2_g", "desc": "Government spending share of manufacturing output.", "kind": "constant", "valueText": "0.3", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-19-beta3_g", "name": "beta3_g", "desc": "Government spending share of services output.", "kind": "constant", "valueText": "0.6", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-20-a11", "name": "a11", "desc": "Agriculture input per unit of agriculture output.", "kind": "constant", "valueText": "0.11", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-21-a12", "name": "a12", "desc": "Agriculture input per unit of manufacturing output.", "kind": "constant", "valueText": "0.12", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-22-a13", "name": "a13", "desc": "Agriculture input per unit of services output.", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-23-a21", "name": "a21", "desc": "Manufacturing input per unit of agriculture output.", "kind": "constant", "valueText": "0.21", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-24-a22", "name": "a22", "desc": "Manufacturing input per unit of manufacturing output.", "kind": "constant", "valueText": "0.22", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-25-a23", "name": "a23", "desc": "Manufacturing input per unit of services output.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-26-a31", "name": "a31", "desc": "Services input per unit of agriculture output.", "kind": "constant", "valueText": "0.15", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-27-a32", "name": "a32", "desc": "Services input per unit of manufacturing output.", "kind": "constant", "valueText": "0.18", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-28-a33", "name": "a33", "desc": "Services input per unit of services output.", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux" } }
      ],
      "collapsed": true
    },
    {
      "id": "initial-values-equations",
      "type": "initial-values",
      "title": "Initial values",
      "modelId": "3io-pc",
      "initialValues": [
        { "id": "init-0-p1", "name": "p1", "desc": "Initial agriculture price.", "valueText": "1" },
        { "id": "init-1-p2", "name": "p2", "desc": "Initial manufacturing price.", "valueText": "1" },
        { "id": "init-2-p3", "name": "p3", "desc": "Initial services price.", "valueText": "1" },
        { "id": "init-3-p_c", "name": "p_c", "desc": "Initial consumer price index.", "valueText": "1" },
        { "id": "init-4-p_g", "name": "p_g", "desc": "Initial government price index.", "valueText": "1" }
      ],
      "collapsed": false
    },
    { "id": "baseline-run", "type": "run", "title": "Baseline run", "description": "Baseline 3IO-PC simulation with hidden-equation condition h_h = h_s.", "mode": "baseline", "periods": 100, "resultKey": "3io_pc_baseline", "sourceModelId": "3io-pc" },
    {
      "id": "baseline-figures-grid",
      "type": "chart-grid",
      "title": "Baseline figures",
      "gridColumns": 2,
      "axisFontSize": 20,
      "charts": [
        {
          "type": "chart",
          "id": "baseline-consistency-chart",
          "title": "Figure 1: consistency check (H_s - H_h)",
          "series": [
            { "expression": "h_s - h_h", "label": "H_s - H_h" }
          ],
          "axisMode": "shared",
          "sharedRange": { "min": -1, "max": 1 },
          "axisSnapTolarance": 0.5,
          "sourceRunCellId": "baseline-run"
        },
        {
          "type": "chart",
          "id": "baseline-income-consumption-chart",
          "title": "Figure 2: disposable income and consumption",
          "series": [
            { "expression": "yd", "label": "Disposable income" },
            { "expression": "cons * p_c", "label": "Nominal consumption" }
          ],
          "axisMode": "shared",
          "axisSnapTolarance": 0.5,
          "sourceRunCellId": "baseline-run"
        },
        {
          "type": "chart",
          "id": "baseline-final-demand-chart",
          "title": "Figure 3: final demand by industry (nominal)",
          "series": [
            { "expression": "nd1", "label": "Agriculture" },
            { "expression": "nd2", "label": "Manufacturing" },
            { "expression": "nd3", "label": "Services" }
          ],
          "axisMode": "shared",
          "axisSnapTolarance": 0.5,
          "sourceRunCellId": "baseline-run"
        },
        { "type": "chart", "id": "baseline-output-chart", "title": "Figure 4: gross output by industry (real)", "variables": ["x1", "x2", "x3"], "axisMode": "shared", "axisSnapTolarance": 0.5, "sourceRunCellId": "baseline-run" },
        { "type": "chart", "id": "baseline-prices-chart", "title": "Figure 5: unit prices by industry", "variables": ["p1", "p2", "p3"], "axisMode": "shared", "axisSnapTolarance": 0.5, "sourceRunCellId": "baseline-run" },
        { "type": "chart", "id": "baseline-price-index-chart", "title": "Figure 6: price indexes by sector", "variables": ["p_c", "p_g"], "axisMode": "shared", "axisSnapTolarance": 0.5, "sourceRunCellId": "baseline-run" }
      ]
    },
    { "id": "baseline-table", "type": "table", "title": "Baseline variable summary", "sourceRunCellId": "baseline-run", "variables": ["y", "yd", "cons", "v", "b_h", "h_h", "p_c", "p_g", "x1", "x2", "x3", "p1", "p2", "p3", "d1", "d2", "d3", "nd1", "nd2", "nd3", "nx1", "nx2", "nx3"] },
    { "id": "scenario-1-note", "type": "markdown", "title": "Government spending scenario", "source": "This scenario raises real government expenditure `g` by 0.1 per period from period 50 until it reaches 23, matching the alternative experiment in `0_3IO-PC-Model.R` (R scenario 2). The notebook uses `runScenario` from the baseline terminal state." },
    {
      "id": "scenario-1-run",
      "type": "run",
      "title": "Scenario 1: higher government spending",
      "mode": "scenario",
      "scenario": {
        "shocks": [
          { "variables": { "g": { "kind": "series", "values": [20.1, 20.2, 20.3, 20.4, 20.5, 20.6, 20.7, 20.8, 20.9, 21, 21.1, 21.2, 21.3, 21.4, 21.5, 21.6, 21.7, 21.8, 21.9, 22, 22.1, 22.2, 22.3, 22.4, 22.5, 22.6, 22.7, 22.8, 22.9, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23, 23] } }, "startPeriodInclusive": 50, "endPeriodInclusive": 100 }
        ]
      },
      "baselineRunCellId": "baseline-run",
      "periods": 100,
      "resultKey": "3io_pc_s1",
      "sourceModelId": "3io-pc",
      "baselineStartPeriod": 48
    },
    {
      "id": "scenario-1-figures-grid",
      "type": "chart-grid",
      "title": "Scenario 1 figures",
      "gridColumns": 2,
      "axisFontSize": 20,
      "charts": [
        {
          "type": "chart",
          "id": "scenario-1-income-consumption-chart",
          "title": "Scenario 1: disposable income and consumption",
          "series": [
            { "expression": "yd", "label": "Disposable income" },
            { "expression": "cons * p_c", "label": "Nominal consumption" }
          ],
          "axisMode": "shared",
          "axisSnapTolarance": 0.5,
          "referenceTrace": "baseline",
          "timeRangeInclusive": [48, 100],
          "sourceRunCellId": "scenario-1-run"
        },
        {
          "type": "chart",
          "id": "scenario-1-final-demand-chart",
          "title": "Scenario 1: final demand by industry (nominal)",
          "series": [
            { "expression": "nd1", "label": "Agriculture" },
            { "expression": "nd2", "label": "Manufacturing" },
            { "expression": "nd3", "label": "Services" }
          ],
          "axisMode": "shared",
          "axisSnapTolarance": 0.5,
          "referenceTrace": "baseline",
          "timeRangeInclusive": [48, 100],
          "sourceRunCellId": "scenario-1-run"
        },
        { "type": "chart", "id": "scenario-1-output-chart", "title": "Scenario 1: gross output by industry (real)", "variables": ["x1", "x2", "x3"], "axisMode": "shared", "axisSnapTolarance": 0.5, "referenceTrace": "baseline", "timeRangeInclusive": [48, 100], "sourceRunCellId": "scenario-1-run" }
      ]
    }
  ]
}
