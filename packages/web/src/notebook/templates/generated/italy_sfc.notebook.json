        { "id": "ext-3-gw", "name": "gw", "kind": "series", "valueText": "0.044648077, -0.013600757, 0.025470815, 0.0256937, 0.033848705, 0.023527897, 0.029972162, 0.020881782, 0.04406568, 0.028902034, 0.030718159, 0.024712593, 0.008425195, 0.022561804, 0.011822996, -0.01134491, 0.006889362, -0.000602018, 0.014278613, 0.012624251, 0.015380515, 0.027562782, 0.017457043, -0.037382413, 0.095301693" },
