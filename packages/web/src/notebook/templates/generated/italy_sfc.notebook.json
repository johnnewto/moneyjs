        { "id": "ext-5-lambdarow", "name": "lambdarow", "kind": "series", "valueText": "0.1439633719, 0.09991092542, 0.1557810606, 0.1530628465, 0.1632828167, 0.1548704382, 0.1690573104, 0.164842353, 0.1726544, 0.2051611851, 0.213699339, 0.2019825198, 0.1800402412, 0.2076893971, 0.2687633296, 0.1847520554, 0.1591042972, 0.08643796522, 0.07464824071, 0.08278462933, 0.09717107964, 0.135892648, 0.07298040633, 0.0391403615, 0.07861096341" },
