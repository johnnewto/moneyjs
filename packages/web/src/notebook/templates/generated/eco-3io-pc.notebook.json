{
  "id": "eco-3io-pc-notebook",
  "title": "ECO-3IO-PC Notebook",
  "metadata": { "version": 1, "template": "eco-3io-pc" },
  "cells": [
    { "id": "intro", "type": "markdown", "title": "Overview", "source": "This notebook ports Marco Veronese Passarella's ECO-3IO-PC prototype from the Florence 2025 keynote. It combines Model PC with a three-industry input-output structure and an ecological block for matter, energy, emissions, and temperature feedback on consumption." },
    {
      "id": "balance-sheet",
      "type": "matrix",
      "title": "ECO-3IO-PC balance sheet",
      "sourceRunCellId": "baseline-run",
      "accountingKind": "balance-sheet",
      "columns": ["Households", "Firms", "Central bank", "Government", "Sum"],
      "sectors": ["Households", "Firms", "Central bank", "Government", ""],
      "rows": [
        { "band": "Cash", "label": "Cash (money)", "values": ["+h_h", "", "-h_s", "", "0"] },
        { "band": "Bills", "label": "Bills", "values": ["+b_h", "", "+b_cb", "-b_s", "0"] },
        { "band": "Wealth", "label": "Wealth", "values": ["-v", "", "", "+b_s", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["0", "0", "0", "0", "0"] }
      ],
      "description": "Balance-sheet matrix for the 3IO-PC macro structure.",
      "note": "Validated against the baseline simulation in the Florence R fixture."
    },
    {
      "id": "transaction-flow",
      "type": "matrix",
      "title": "ECO-3IO-PC transactions-flow matrix",
      "sourceRunCellId": "baseline-run",
      "accountingKind": "transaction-flow",
      "columns": ["Households", "Firms", "Central bank", "Government", "Sum"],
      "sectors": ["Households", "Firms", "Central bank", "Government", ""],
      "rows": [
        { "band": "Consumption", "label": "Consumption", "values": ["-cons * p_c", "+cons * p_c", "", "", "0"] },
        { "band": "Government", "label": "Government expenditure", "values": ["", "+g * p_g", "", "-g * p_g", "0"] },
        { "band": "Income", "label": "GDP (income)", "values": ["+y", "-y", "", "", "0"] },
        { "band": "Interest", "label": "Interest payments", "values": ["+lag(r) * lag(b_h)", "", "+lag(r) * lag(b_cb)", "-lag(r) * lag(b_s)", "0"] },
        { "band": "Profits", "label": "CB profit", "values": ["", "", "-lag(r) * lag(b_cb)", "+lag(r) * lag(b_cb)", "0"] },
        { "band": "Taxes", "label": "Taxes", "values": ["-t", "", "", "+t", "0"] },
        { "band": "Cash", "label": "Change in cash", "values": ["-d(h_h)", "", "+d(h_s)", "", "0"] },
        { "band": "Bills", "label": "Change in bills", "values": ["-d(b_h)", "", "-d(b_cb)", "+d(b_s)", "0"] },
        { "band": "Sum", "label": "Sum", "values": ["0", "0", "0", "0", "0"] }
      ],
      "description": "Transactions-flow matrix for the 3IO-PC macro structure.",
      "note": "Validated against the baseline simulation in the Florence R fixture."
    },
    { "id": "transaction-flow-sequence", "type": "sequence", "title": "ECO-3IO-PC transaction flow sequence", "source": { "kind": "matrix", "matrixCellId": "transaction-flow" }, "description": "Sequence view generated from the transactions-flow matrix at the selected simulation period." },
    {
      "id": "equations",
      "type": "equations",
      "title": "ECO-3IO-PC model",
      "modelId": "eco-3io-pc",
      "equations": [
        { "id": "eq-0-d1", "name": "d1", "desc": "Final demand for agriculture.", "expression": "beta1_c * cons + beta1_g * g", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-1-d2", "name": "d2", "desc": "Final demand for manufacturing.", "expression": "beta2_c * cons + beta2_g * g", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-2-d3", "name": "d3", "desc": "Final demand for services.", "expression": "beta3_c * cons + beta3_g * g", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-3-x1", "name": "x1", "desc": "Gross output in agriculture.", "expression": "a11 * x1 + a12 * x2 + a13 * x3 + d1", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-4-x2", "name": "x2", "desc": "Gross output in manufacturing.", "expression": "a21 * x1 + a22 * x2 + a23 * x3 + d2", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-5-x3", "name": "x3", "desc": "Gross output in services.", "expression": "a31 * x1 + a32 * x2 + a33 * x3 + d3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-6-y", "name": "y", "desc": "Nominal GDP from final demands.", "expression": "p1 * d1 + p2 * d2 + p3 * d3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-7-p1", "name": "p1", "desc": "Unit price in agriculture.", "expression": "(w / pr1) + (p1 * a11 + p2 * a21 + p3 * a31) * (1 + mu)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-8-p2", "name": "p2", "desc": "Unit price in manufacturing.", "expression": "(w / pr2) + (p1 * a12 + p2 * a22 + p3 * a32) * (1 + mu)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-9-p3", "name": "p3", "desc": "Unit price in services.", "expression": "(w / pr3) + (p1 * a13 + p2 * a23 + p3 * a33) * (1 + mu)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-10-p_c", "name": "p_c", "desc": "Consumer price index.", "expression": "p1 * beta1_c + p2 * beta2_c + p3 * beta3_c", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "money": 1, "items": -1 } } },
        { "id": "eq-11-p_g", "name": "p_g", "desc": "Government purchase price index.", "expression": "p1 * beta1_g + p2 * beta2_g + p3 * beta3_g", "role": "identity", "unitMeta": { "stockFlow": "flow" } },
        { "id": "eq-12-yd", "name": "yd", "desc": "Household disposable income.", "expression": "y - t + lag(r) * lag(b_h)", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-13-v", "name": "v", "desc": "Household wealth.", "expression": "I(yd - p_c * cons)", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-14-infl", "name": "infl", "desc": "Inflation tax on lagged wealth.", "expression": "(d(p_c) / p_c') * (v' / p_c)", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-15-cons", "name": "cons", "desc": "Real consumption without monetary illusion.", "expression": "alpha1 * ((yd / p_c) - infl) + alpha2 * lag(v) / p_c", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "eq-16-alpha1", "name": "alpha1", "desc": "Endogenous propensity to consume out of income.", "expression": "alpha10 - alpha11 * lag(r) - alpha12 * (temp - lag(temp))", "role": "identity", "unitMeta": { "stockFlow": "aux" } },
        { "id": "eq-17-h_h", "name": "h_h", "desc": "Household cash holdings.", "expression": "v - b_h", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-18-b_h", "name": "b_h", "desc": "Household bill holdings.", "expression": "v * (lambda0 + lambda1 * r - lambda2 * (yd / v))", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-19-t", "name": "t", "desc": "Income and interest taxes.", "expression": "theta * (y + lag(r) * lag(b_h))", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "money": 1, "time": -1 } } },
        { "id": "eq-20-b_s", "name": "b_s", "desc": "Government bill supply.", "expression": "I(p_g * g + lag(r) * lag(b_s) - t - lag(r) * lag(b_cb))", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-21-h_s", "name": "h_s", "desc": "High-powered money supply.", "expression": "I(b_cb - lag(b_cb))", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-22-b_cb", "name": "b_cb", "desc": "Central-bank bill holdings.", "expression": "b_s - b_h", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "money": 1 } } },
        { "id": "eq-23-x_mat", "name": "x_mat", "desc": "Production of material goods.", "expression": "mu_mat1 * x1 + mu_mat2 * x2 + mu_mat3 * x3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-24-rec", "name": "rec", "desc": "Recycled socioeconomic stock.", "expression": "rho_dis * dis", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-25-dis", "name": "dis", "desc": "Discarded socioeconomic stock.", "expression": "mu_mat1 * zeta_dc1 * lag(dc1) + mu_mat2 * zeta_dc2 * lag(dc2) + mu_mat3 * zeta_dc3 * lag(dc3)", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-26-dc1", "name": "dc1", "desc": "Durable stock of product 1.", "expression": "(1 - zeta_dc1) * lag(dc1) + beta1_c * cons", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-27-dc2", "name": "dc2", "desc": "Durable stock of product 2.", "expression": "(1 - zeta_dc2) * lag(dc2) + beta2_c * cons", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-28-dc3", "name": "dc3", "desc": "Durable stock of product 3.", "expression": "(1 - zeta_dc3) * lag(dc3) + beta3_c * cons", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-29-mat", "name": "mat", "desc": "Extracted matter.", "expression": "x_mat - rec", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-30-kh", "name": "kh", "desc": "Socioeconomic stock of matter.", "expression": "I(x_mat - dis)", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-31-wa", "name": "wa", "desc": "Waste flow.", "expression": "mat - (kh - lag(kh))", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-32-en", "name": "en", "desc": "Total energy use.", "expression": "eps_en1 * x1 + eps_en2 * x2 + eps_en3 * x3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "energy": 1, "time": -1 } } },
        { "id": "eq-33-ren", "name": "ren", "desc": "Renewable energy use.", "expression": "eps_en1 * eta_en1 * x1 + eps_en2 * eta_en2 * x2 + eps_en3 * eta_en3 * x3", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "energy": 1, "time": -1 } } },
        { "id": "eq-34-nen", "name": "nen", "desc": "Non-renewable energy use.", "expression": "en - ren", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "energy": 1, "time": -1 } } },
        { "id": "eq-35-emis", "name": "emis", "desc": "Annual CO2 emissions.", "expression": "beta_e * nen", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-36-emis1", "name": "emis1", "desc": "CO2 emissions from agriculture.", "expression": "eps_en1 * (1 - eta_en1) * x1 * beta_e", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-37-emis2", "name": "emis2", "desc": "CO2 emissions from manufacturing.", "expression": "eps_en2 * (1 - eta_en2) * x2 * beta_e", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-38-emis3", "name": "emis3", "desc": "CO2 emissions from services.", "expression": "eps_en3 * (1 - eta_en3) * x3 * beta_e", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-39-depl_m_pct", "name": "depl_m_pct", "desc": "Matter reserves depletion rate.", "expression": "100 * mat / lag(k_m)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "eq-40-depl_e_pct", "name": "depl_e_pct", "desc": "Energy reserves depletion rate.", "expression": "100 * nen / lag(k_e)", "role": "identity", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "eq-41-beta_e", "name": "beta_e", "desc": "CO2 intensity of non-renewable energy.", "expression": "lag(beta_e) * (1 - g_beta_e)", "role": "identity", "unitMeta": { "stockFlow": "aux" } },
        { "id": "eq-42-co2_cum", "name": "co2_cum", "desc": "Cumulative CO2 emissions.", "expression": "I(emis)", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-43-temp", "name": "temp", "desc": "Atmospheric temperature response.", "expression": "(tcre / (1 - fnc)) * co2_cum", "role": "identity", "unitMeta": { "stockFlow": "stock", "signature": { "carbon": 1 } } },
        { "id": "eq-44-k_m", "name": "k_m", "desc": "Matter reserves.", "expression": "I(conv_m - mat)", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-45-conv_m", "name": "conv_m", "desc": "Matter resources converted to reserves.", "expression": "sigma_m * res_m", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-46-res_m", "name": "res_m", "desc": "Matter resource stock.", "expression": "lag(res_m) - conv_m*dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "mass": 1 } } },
        { "id": "eq-47-cen", "name": "cen", "desc": "Carbon mass of energy use.", "expression": "emis / car", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-48-o2", "name": "o2", "desc": "Oxygen mass flow.", "expression": "emis - cen", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "mass": 1, "time": -1 } } },
        { "id": "eq-49-k_e", "name": "k_e", "desc": "Energy reserves.", "expression": "I(conv_e - nen)", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "energy": 1 } } },
        { "id": "eq-50-conv_e", "name": "conv_e", "desc": "Energy resources converted to reserves.", "expression": "sigma_e * res_e", "role": "identity", "unitMeta": { "stockFlow": "flow", "signature": { "energy": 1, "time": -1 } } },
        { "id": "eq-51-res_e", "name": "res_e", "desc": "Energy resource stock.", "expression": "lag(res_e) - conv_e*dt", "role": "accumulation", "unitMeta": { "stockFlow": "stock", "signature": { "energy": 1 } } }
      ],
      "collapsed": false
    },
    { "id": "solver", "type": "solver", "title": "Solver", "modelId": "eco-3io-pc", "options": { "solverMethod": "GAUSS_SEIDEL", "toleranceText": "1e-10", "maxIterations": 200, "defaultInitialValueText": "0", "hiddenLeftVariable": "h_h", "hiddenRightVariable": "h_s", "hiddenToleranceText": "1e-6", "relativeHiddenTolerance": false }, "collapsed": true },
    {
      "id": "externals-equations",
      "type": "externals",
      "title": "Externals",
      "modelId": "eco-3io-pc",
      "externals": [
        { "id": "ext-0-r", "name": "r", "desc": "Interest rate on government bills.", "kind": "constant", "valueText": "0.025", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-1-g", "name": "g", "desc": "Real government expenditure.", "kind": "constant", "valueText": "20", "unitMeta": { "stockFlow": "flow", "signature": { "items": 1, "time": -1 } } },
        { "id": "ext-2-alpha10", "name": "alpha10", "desc": "Autonomous propensity to consume out of income.", "kind": "constant", "valueText": "0.8", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-3-alpha11", "name": "alpha11", "desc": "Interest-rate elasticity of consumption propensity.", "kind": "constant", "valueText": "8", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-4-alpha12", "name": "alpha12", "desc": "Temperature-change elasticity of consumption propensity.", "kind": "constant", "valueText": "0", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-5-alpha2", "name": "alpha2", "desc": "Propensity to consume out of lagged wealth.", "kind": "constant", "valueText": "0.4" },
        { "id": "ext-6-w", "name": "w", "desc": "Uniform wage rate.", "kind": "constant", "valueText": "0.4", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-7-mu", "name": "mu", "desc": "Uniform markup.", "kind": "constant", "valueText": "0.875", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-8-pr1", "name": "pr1", "desc": "Labour productivity in agriculture.", "kind": "constant", "valueText": "3.5", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-9-pr2", "name": "pr2", "desc": "Labour productivity in manufacturing.", "kind": "constant", "valueText": "5", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-10-pr3", "name": "pr3", "desc": "Labour productivity in services.", "kind": "constant", "valueText": "2.2", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-11-lambda0", "name": "lambda0", "desc": "Autonomous portfolio share of bills.", "kind": "constant", "valueText": "0.635", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-12-lambda1", "name": "lambda1", "desc": "Interest elasticity of bill demand.", "kind": "constant", "valueText": "5", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-13-lambda2", "name": "lambda2", "desc": "Income elasticity of bill demand.", "kind": "constant", "valueText": "0.01", "unitMeta": { "stockFlow": "aux", "signature": { "time": 1 } } },
        { "id": "ext-14-theta", "name": "theta", "desc": "Tax rate on income and interest.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-15-beta1_c", "name": "beta1_c", "desc": "Consumption share of agriculture output.", "kind": "constant", "valueText": "0.15", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-16-beta2_c", "name": "beta2_c", "desc": "Consumption share of manufacturing output.", "kind": "constant", "valueText": "0.35", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-17-beta3_c", "name": "beta3_c", "desc": "Consumption share of services output.", "kind": "constant", "valueText": "0.5", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-18-beta1_g", "name": "beta1_g", "desc": "Government spending share of agriculture output.", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-19-beta2_g", "name": "beta2_g", "desc": "Government spending share of manufacturing output.", "kind": "constant", "valueText": "0.3", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-20-beta3_g", "name": "beta3_g", "desc": "Government spending share of services output.", "kind": "constant", "valueText": "0.6", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-21-a11", "name": "a11", "desc": "Agriculture input per unit of agriculture output.", "kind": "constant", "valueText": "0.11", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-22-a12", "name": "a12", "desc": "Agriculture input per unit of manufacturing output.", "kind": "constant", "valueText": "0.12", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-23-a13", "name": "a13", "desc": "Agriculture input per unit of services output.", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-24-a21", "name": "a21", "desc": "Manufacturing input per unit of agriculture output.", "kind": "constant", "valueText": "0.21", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-25-a22", "name": "a22", "desc": "Manufacturing input per unit of manufacturing output.", "kind": "constant", "valueText": "0.22", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-26-a23", "name": "a23", "desc": "Manufacturing input per unit of services output.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-27-a31", "name": "a31", "desc": "Services input per unit of agriculture output.", "kind": "constant", "valueText": "0.15", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-28-a32", "name": "a32", "desc": "Services input per unit of manufacturing output.", "kind": "constant", "valueText": "0.18", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-29-a33", "name": "a33", "desc": "Services input per unit of services output.", "kind": "constant", "valueText": "0.1", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-30-rho_dis", "name": "rho_dis", "desc": "Recycling rate of discarded stock.", "kind": "constant", "valueText": "0.2", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-31-g_beta_e", "name": "g_beta_e", "desc": "Decline rate of CO2 intensity.", "kind": "constant", "valueText": "0.01", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-32-tcre", "name": "tcre", "desc": "Transient climate response to cumulative emissions.", "kind": "constant", "valueText": "0.00165", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-33-fnc", "name": "fnc", "desc": "Non-CO2 share of anthropogenic forcing.", "kind": "constant", "valueText": "0.34", "unitMeta": { "stockFlow": "aux" } },
        { "id": "ext-34-sigma_m", "name": "sigma_m", "desc": "Matter resource conversion rate.", "kind": "constant", "valueText": "0.0005", "unitMeta": { "stockFlow": "aux", "signature": { "time": -1 } } },
        { "id": "ext-35-car", "name": "car", "desc": "Carbon-to-CO2 conversion coefficient.", "kind": "constant", "valueText": "3.67", "unitMeta": { "stockFlow": "aux" } },
