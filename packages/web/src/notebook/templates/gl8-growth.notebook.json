{
  "id": "gl8-growth-notebook",
  "title": "GL8 Growth Notebook",
  "metadata": { "version": 1, "template": "gl8-growth" },
  "cells": [
    { "id": "intro", "type": "markdown", "title": "Overview", "source": "This notebook adapts the `gl8-growth.Rmd` article into executable browser cells. It includes the full GROWTH baseline, the balance-sheet and transactions-flow matrices, and three representative policy experiments from the article: a higher target real wage, a one-period fiscal-growth shock, and a rise in non-performing loans." },
    {
      "id": "balance-sheet",
      "type": "matrix",
      "title": "GROWTH balance sheet",
      "sourceRunCellId": "baseline-run",
      "columns": ["Households", "Firms", "Govt", "Central Bank", "Banks", "Sum"],
      "rows": [
        { "label": "Inventories", "values": ["", "+IN", "", "", "", "+IN"] },
        { "label": "Fixed capital", "values": ["", "+K", "", "", "", "+K"] },
        { "label": "HPM", "values": ["+Hhd", "", "", "-Hs", "+Hbd", "0"] },
        { "label": "Money", "values": ["+Mh", "", "", "", "-Ms", "0"] },
        { "label": "Bills", "values": ["+Bhd", "", "-Bs", "+Bcbd", "+Bbd", "0"] },
        { "label": "Bonds", "values": ["+BLd * Pbl", "", "-BLs * Pbl", "", "", "0"] },
        { "label": "Loans", "values": ["-Lhd", "-Lfd", "", "", "+Ls", "0"] },
        { "label": "Equities", "values": ["+Ekd * Pe", "-Eks * Pe", "", "", "", "0"] },
        { "label": "Bank capital", "values": ["+OFb", "", "", "", "-OFb", "0"] },
        { "label": "Balance", "values": ["-V", "-Vf", "GD", "", "", "-(IN + K)"] }
      ],
      "description": "Balance-sheet matrix for model GROWTH following the gl8 article.",
      "note": "Validated against the baseline simulation in the R vignette fixture."
    },
    {
      "id": "transaction-flow",
      "type": "matrix",
      "title": "GROWTH transactions-flow matrix",
      "sourceRunCellId": "baseline-run",
      "columns": ["Households", "Firms curr.", "Firms cap.", "Govt.", "CB curr.", "CB cap.", "Banks curr.", "Banks cap."],
      "rows": [
        { "label": "Consumption", "values": ["-CONS", "+CONS", "", "", "", "", "", ""] },
        { "label": "Govt. exp.", "values": ["", "+G", "", "-G", "", "", "", ""] },
        { "label": "Investment", "values": ["", "+INV", "-INV", "", "", "", "", ""] },
        { "label": "Inventories", "values": ["", "+(IN - IN[-1])", "-(IN - IN[-1])", "", "", "", "", ""] },
        { "label": "Taxes", "values": ["-TX", "", "", "+TX", "", "", "", ""] },
        { "label": "Wages", "values": ["+WB", "-WB", "", "", "", "", "", ""] },
        { "label": "Inventory financing cost", "values": ["", "-Rl[-1] * IN[-1]", "", "", "", "", "+Rl[-1] * IN[-1]", ""] },
        { "label": "Entrepreneurial profits", "values": ["+FDf", "-Ff", "+FUf", "", "", "", "+Rl[-1] * (Lfs[-1] - IN[-1] - NPL)", ""] },
        { "label": "Banks profits", "values": ["+FDb", "", "", "", "", "", "-Fb", "+FUb"] },
        { "label": "Int. hh loans", "values": ["-Rl[-1] * Lhd[-1]", "", "", "", "", "", "+Rl[-1] * Lhs[-1]", ""] },
        { "label": "Int. deposits", "values": ["+Rm[-1] * Mh[-1]", "", "", "", "", "", "-Rm[-1] * Ms[-1]", ""] },
        { "label": "Int. bills", "values": ["+Rb[-1] * Bhd[-1]", "", "", "-Rb[-1] * Bs[-1]", "+Rb[-1] * Bcbd[-1]", "", "+Rb[-1] * Bbd[-1]", ""] },
        { "label": "Int. bonds", "values": ["+BLd[-1]", "", "", "-BLd[-1]", "", "", "", ""] },
        { "label": "Ch. loans", "values": ["+(Lhd - Lhd[-1])", "", "+(Lfd - Lfd[-1])", "", "", "", "", "-(Ls - Ls[-1])"] },
        { "label": "Ch. cash", "values": ["-(Hhd - Hhd[-1])", "", "", "", "", "+(Hs - Hs[-1])", "", "-(Hbd - Hbd[-1])"] },
        { "label": "Ch. deposits", "values": ["-(Mh - Mh[-1])", "", "", "", "", "", "", "+(Ms - Ms[-1])"] },
        { "label": "Ch. bills", "values": ["-(Bhd - Bhd[-1])", "", "", "+(Bs - Bs[-1])", "", "-(Bcbd - Bcbd[-1])", "", "-(Bbd - Bbd[-1])"] },
        { "label": "Ch. bonds", "values": ["-(BLd - BLd[-1]) * Pbl", "", "", "+(BLs - BLs[-1]) * Pbl", "", "", "", ""] },
        { "label": "Ch. equities", "values": ["-(Ekd - Ekd[-1]) * Pe", "", "+(Eks - Eks[-1]) * Pe", "", "", "", "", ""] },
        { "label": "Loan defaults", "values": ["", "", "+NPL", "", "", "", "", "-NPL"] }
      ],
      "description": "Transactions-flow matrix for model GROWTH following the gl8 article.",
      "note": "Validated against the baseline simulation in the R vignette fixture."
    },
    { "id": "transaction-flow-sequence", "type": "sequence", "title": "GROWTH transaction flow sequence", "source": { "kind": "matrix", "matrixCellId": "transaction-flow" }, "description": "Sequence view generated from the GROWTH transactions-flow matrix at the selected simulation period." },
    { "id": "equation-dependency-graph", "type": "sequence", "title": "GROWTH equation dependency graph", "source": { "kind": "dependency", "modelId": "equations" }, "description": "Layered dependency view of the GROWTH equations. Left-to-right position shows dependency depth and top-to-bottom order follows the notebook equation list within each layer.", "note": "This view is intentionally dense. Use it to inspect how the large GROWTH model clusters into exogenous inputs, intermediate flows, and downstream stocks." },
    {
      "id": "equations",
      "type": "equations",
      "title": "GROWTH model",
      "modelId": "equations",
      "equations": [
        { "id": "eq-0-Yk", "name": "Yk", "desc": "Real output", "expression": "Ske + INke - INk[-1]" },
        { "id": "eq-1-Ske", "name": "Ske", "desc": "Expected real sales", "expression": "beta * Sk + (1 - beta) * Sk[-1] * (1 + (GRpr + RA))" },
        { "id": "eq-2-INke", "name": "INke", "desc": "Expected real inventories", "expression": "INk[-1] + gamma * (INkt - INk[-1])" },
        { "id": "eq-3-INkt", "name": "INkt", "desc": "Target level of real inventories", "expression": "sigmat * Ske" },
        { "id": "eq-4-INk", "name": "INk", "desc": "Real inventories", "expression": "INk[-1] + Yk - Sk - NPL / UC" },
        { "id": "eq-5-Kk", "name": "Kk", "desc": "Real capital stock", "expression": "Kk[-1] * (1 + GRk)" },
        { "id": "eq-6-GRk", "name": "GRk", "desc": "growth_mod of real capital stock", "expression": "gamma0 + gammau * U[-1] - gammar * RRl" },
        { "id": "eq-7-U", "name": "U", "desc": "Capital utilization proxy", "expression": "Yk / Kk[-1]" },
        { "id": "eq-8-RRl", "name": "RRl", "desc": "Real interest rate on loans", "expression": "((1 + Rl) / (1 + PI)) - 1" },
        { "id": "eq-9-PI", "name": "PI", "desc": "Price inflation", "expression": "(P - P[-1]) / P[-1]" },
        { "id": "eq-10-Ik", "name": "Ik", "desc": "Gross investment in real terms", "expression": "(Kk - Kk[-1]) + delta * Kk[-1]" },
        { "id": "eq-11-Sk", "name": "Sk", "desc": "Real sales", "expression": "Ck + Gk + Ik" },
        { "id": "eq-12-S", "name": "S", "desc": "Sales at current prices", "expression": "Sk * P" },
        { "id": "eq-13-IN", "name": "IN", "desc": "Stock of inventories at current costs", "expression": "INk * UC" },
        { "id": "eq-14-INV", "name": "INV", "desc": "Gross investment", "expression": "Ik * P" },
        { "id": "eq-15-K", "name": "K", "desc": "Capital stock", "expression": "Kk * P" },
        { "id": "eq-16-Y", "name": "Y", "desc": "Output at current prices (nominal GDP ", "expression": "Sk * P + (INk - INk[-1]) * UC" },
        { "id": "eq-17-omegat", "name": "omegat", "desc": "Target real wage for workers", "expression": "exp(omega0 + omega1 * log(PR) + omega2 * log(ER + z3 * (1 - ER) - z4 * BANDt + z5 * BANDb))" },
        { "id": "eq-18-ER", "name": "ER", "desc": "Employment rate", "expression": "N[-1] / Nfe[-1]" },
        { "id": "eq-19-z3a", "name": "z3a", "desc": "", "expression": "if (ER > (1 - BANDb)) {1} else {0}" },
        { "id": "eq-20-z3b", "name": "z3b", "desc": "", "expression": "if (ER <= (1 + BANDt)) {1} else {0}" },
        { "id": "eq-21-z3", "name": "z3", "desc": "Parameter in wage aspiration equation", "expression": "z3a * z3b" },
        { "id": "eq-22-z4", "name": "z4", "desc": "Parameter in wage aspiration equation", "expression": "if (ER > (1 + BANDt)) {1} else {0}" },
        { "id": "eq-23-z5", "name": "z5", "desc": "Parameter in wage aspiration equation", "expression": "if (ER < (1 - BANDb)) {1} else {0}" },
        { "id": "eq-24-W", "name": "W", "desc": "Wage rate", "expression": "W[-1] + omega3 * (omegat * P[-1] - W[-1])" },
        { "id": "eq-25-PR", "name": "PR", "desc": "Lobor productivity", "expression": "PR[-1] * (1 + GRpr)" },
        { "id": "eq-26-Nt", "name": "Nt", "desc": "Desired employment level", "expression": "Yk / PR" },
        { "id": "eq-27-N", "name": "N", "desc": "Employment level", "expression": "N[-1] + etan * (Nt - N[-1])" },
        { "id": "eq-28-WB", "name": "WB", "desc": "The wage bill", "expression": "N * W" },
        { "id": "eq-29-UC", "name": "UC", "desc": "Unit costs", "expression": "WB / Yk" },
        { "id": "eq-30-NUC", "name": "NUC", "desc": "Normal unit cost", "expression": "W / PR" },
        { "id": "eq-31-NHUC", "name": "NHUC", "desc": "Normal historic unit cost", "expression": "(1 - sigman) * NUC + sigman * (1 + Rln[-1]) * NUC[-1]" },
        { "id": "eq-32-P", "name": "P", "desc": "Price level", "expression": "(1 + phi) * NHUC" },
        { "id": "eq-33-phi", "name": "phi", "desc": "Mark-up on unit costs", "expression": "phi[-1] + eps2 * (phit[-1] - phi[-1])" },
        { "id": "eq-34-phit", "name": "phit", "desc": "Ideal mark-up on unit costs", "expression": "(FUft + FDf + Rl[-1] * (Lfd[-1] - IN[-1])) / ((1 - sigmase) * Ske * UC + (1 + Rl[-1]) * sigmase * Ske * UC[-1])" },
        { "id": "eq-35-HCe", "name": "HCe", "desc": "Expected historical costs", "expression": "(1 - sigmase) * Ske * UC + (1 + Rl[-1]) * sigmase * Ske * UC[-1]" },
        { "id": "eq-36-sigmase", "name": "sigmase", "desc": "Opening inventories to expected sales ratio", "expression": "INk[-1] / Ske" },
        { "id": "eq-37-Fft", "name": "Fft", "desc": "Planned entrepreneurial profits", "expression": "FUft + FDf + Rl[-1] * (Lfd[-1] - IN[-1])" },
        { "id": "eq-38-FUft", "name": "FUft", "desc": "Planned retained earnings of firms", "expression": "psiu * INV[-1]" },
        { "id": "eq-39-FDf", "name": "FDf", "desc": "Dividends of firms", "expression": "psid * Ff[-1]" },
        { "id": "eq-40-Ff", "name": "Ff", "desc": "Realized entrepreneurial profits", "expression": "S - WB + (IN - IN[-1]) - Rl[-1] * IN[-1]" },
        { "id": "eq-41-FUf", "name": "FUf", "desc": "Retained earnings of firms", "expression": "Ff - FDf - Rl[-1] * (Lfd[-1] - IN[-1]) + Rl[-1] * NPL" },
        { "id": "eq-42-Lfd", "name": "Lfd", "desc": "Demand for loans by firms", "expression": "Lfd[-1] + INV + (IN - IN[-1]) - FUf - (Eks - Eks[-1]) * Pe - NPL" },
        { "id": "eq-43-NPL", "name": "NPL", "desc": "Non-Performing loans", "expression": "NPLk * Lfs[-1]" },
        { "id": "eq-44-Eks", "name": "Eks", "desc": "Number of equities supplied by firms", "expression": "Eks[-1] + ((1 - psiu) * INV[-1]) / Pe" },
        { "id": "eq-45-Rk", "name": "Rk", "desc": "Dividend yield of firms", "expression": "FDf / (Pe[-1] * Ekd[-1])" },
        { "id": "eq-46-PE", "name": "PE", "desc": "Price earnings ratio", "expression": "Pe / (Ff / Eks[-1])" },
        { "id": "eq-47-Q", "name": "Q", "desc": "Tobin's Q", "expression": "(Eks * Pe + Lfd) / (K + IN)" },
        { "id": "eq-48-YP", "name": "YP", "desc": "Personal income", "expression": "WB + FDf + FDb + Rm[-1] * Mh[-1] + Rb[-1] * Bhd[-1] + BLs[-1]" },
        { "id": "eq-49-TX", "name": "TX", "desc": "Taxes", "expression": "theta * YP" },
        { "id": "eq-50-YDr", "name": "YDr", "desc": "Regular disposable income", "expression": "YP - TX - Rl[-1] * Lhd[-1]" },
        { "id": "eq-51-YDhs", "name": "YDhs", "desc": "Haig-Simons measure of disposable income", "expression": "YDr + CG" },
        { "id": "eq-52-CG", "name": "CG", "desc": "Capital gains on government bonds", "expression": "(Pbl - Pbl[-1]) * BLd[-1] + (Pe - Pe[-1]) * Ekd[-1] + (OFb - OFb[-1])" },
        { "id": "eq-53-V", "name": "V", "desc": "Wealth of households", "expression": "V[-1] + YDr - CONS + (Pbl - Pbl[-1]) * BLd[-1] + (Pe - Pe[-1]) * Ekd[-1] + (OFb - OFb[-1])" },
        { "id": "eq-54-Vk", "name": "Vk", "desc": "Real wealth of households", "expression": "V / P" },
        { "id": "eq-55-CONS", "name": "CONS", "desc": "Consumption at current prices", "expression": "Ck * P" },
        { "id": "eq-56-Ck", "name": "Ck", "desc": "Real consumption", "expression": "alpha1 * (YDkre + NLk) + alpha2 * Vk[-1]" },
        { "id": "eq-57-YDkre", "name": "YDkre", "desc": "Expected regular real disposable income", "expression": "eps * YDkr + (1 - eps) * (YDkr[-1] * (1 + GRpr))" },
        { "id": "eq-58-YDkr", "name": "YDkr", "desc": "Regular real disposable income", "expression": "YDr / P - ((P - P[-1]) * Vk[-1]) / P" },
        { "id": "eq-59-GL", "name": "GL", "desc": "Gross amount of new personal loans", "expression": "eta * YDr" },
        { "id": "eq-60-eta", "name": "eta", "desc": "Ratio of new loans to personal income", "expression": "eta0 - etar * RRl" },
        { "id": "eq-61-NL", "name": "NL", "desc": "Net flow of new loans to the household sector", "expression": "GL - REP" },
        { "id": "eq-62-REP", "name": "REP", "desc": "Personal loans repayments", "expression": "deltarep * Lhd[-1]" },
        { "id": "eq-63-Lhd", "name": "Lhd", "desc": "Demand for loans by households", "expression": "Lhd[-1] + GL - REP" },
        { "id": "eq-64-NLk", "name": "NLk", "desc": "Real flow of new loans to the household sector", "expression": "NL / P" },
        { "id": "eq-65-BUR", "name": "BUR", "desc": "Burden of personal debt", "expression": "(REP + Rl[-1] * Lhd[-1]) / YDr[-1]" },
        { "id": "eq-66-Bhd", "name": "Bhd", "desc": "Demand for government bills from households", "expression": "Vfma[-1] * (lambda20 + lambda22 * Rb[-1] - lambda21 * Rm[-1] - lambda24 * Rk[-1] - lambda23 * Rbl[-1] - lambda25 * (YDr / V))" },
        { "id": "eq-67-BLd", "name": "BLd", "desc": "Demand for government bonds", "expression": "Vfma[-1] * (lambda30 - lambda32 * Rb[-1] - lambda31 * Rm[-1] - lambda34 * Rk[-1] + lambda33 * Rbl[-1] - lambda35 * (YDr / V)) / Pbl" },
        { "id": "eq-68-Pe", "name": "Pe", "desc": "Price of equities", "expression": "Vfma[-1] * (lambda40 - lambda42 * Rb[-1] - lambda41 * Rm[-1] + lambda44 * Rk[-1] - lambda43 * Rbl[-1] - lambda45 * (YDr / V)) / Ekd" },
        { "id": "eq-69-Mh", "name": "Mh", "desc": "Deposits demanded by households", "expression": "Vfma - Bhd - Pe * Ekd - Pbl * BLd + Lhd" },
        { "id": "eq-70-Vfma", "name": "Vfma", "desc": "Investible wealth of households", "expression": "V - Hhd - OFb" },
        { "id": "eq-71-VfmaA", "name": "VfmaA", "desc": "", "expression": "Mh + Bhd + Pbl * BLd + Pe * Ekd" },
        { "id": "eq-72-Hhd", "name": "Hhd", "desc": "Households demand for cash", "expression": "lambdac * CONS" },
        { "id": "eq-73-Ekd", "name": "Ekd", "desc": "Number of equities demanded", "expression": "Eks" },
        { "id": "eq-74-G", "name": "G", "desc": "Government expenditures", "expression": "Gk * P" },
        { "id": "eq-75-Gk", "name": "Gk", "desc": "Real government expenditures", "expression": "Gk[-1] * (1 + GRg)" },
        { "id": "eq-76-PSBR", "name": "PSBR", "desc": "Government deficit", "expression": "G + BLs[-1] + Rb[-1] * (Bbs[-1] + Bhs[-1]) - TX" },
        { "id": "eq-77-Bs", "name": "Bs", "desc": "Supply of government bills", "expression": "Bs[-1] + G - TX - (BLs - BLs[-1]) * Pbl + Rb[-1] * (Bhs[-1] + Bbs[-1]) + BLs[-1]" },
        { "id": "eq-78-GD", "name": "GD", "desc": "Government debt", "expression": "Bbs + Bhs + BLs * Pbl + Hs" },
        { "id": "eq-79-Fcb", "name": "Fcb", "desc": "Central bank \"profits\"", "expression": "Rb[-1] * Bcbd[-1]" },
        { "id": "eq-80-BLs", "name": "BLs", "desc": "Supply of government bonds", "expression": "BLd" },
        { "id": "eq-81-Bhs", "name": "Bhs", "desc": "Government bills supplied to households", "expression": "Bhd" },
        { "id": "eq-82-Hhs", "name": "Hhs", "desc": "Cash supplied to households", "expression": "Hhd" },
        { "id": "eq-83-Hbs", "name": "Hbs", "desc": "Cash supplied to banks", "expression": "Hbd" },
        { "id": "eq-84-Hs", "name": "Hs", "desc": "Total supply of cash", "expression": "Hbs + Hhs" },
        { "id": "eq-85-Bcbd", "name": "Bcbd", "desc": "Government bills demanded by Central bank", "expression": "Hs" },
        { "id": "eq-86-Bcbs", "name": "Bcbs", "desc": "Government bills supplied by Central bank", "expression": "Bcbd" },
        { "id": "eq-87-Rb", "name": "Rb", "desc": "Interest rate on government bills", "expression": "Rbbar" },
        { "id": "eq-88-Rbl", "name": "Rbl", "desc": "Interest rate on bonds", "expression": "Rb + ADDbl" },
        { "id": "eq-89-Pbl", "name": "Pbl", "desc": "Price of government bonds", "expression": "1 / Rbl" },
        { "id": "eq-90-Ms", "name": "Ms", "desc": "Deposits supplied by banks", "expression": "Mh" },
        { "id": "eq-91-Lfs", "name": "Lfs", "desc": "Supply of loans to firms", "expression": "Lfd" },
        { "id": "eq-92-Lhs", "name": "Lhs", "desc": "Loans supplied to households", "expression": "Lhd" },
        { "id": "eq-93-Hbd", "name": "Hbd", "desc": "Cash required by banks", "expression": "ro * Ms" },
        { "id": "eq-94-Bbs", "name": "Bbs", "desc": "Government bills supplied to commercial banks", "expression": "Bbs[-1] + (Bs - Bs[-1]) - (Bhs - Bhs[-1]) - (Bcbs - Bcbs[-1])" },
        { "id": "eq-95-Bbd", "name": "Bbd", "desc": "Government bills demanded by commercial banks", "expression": "Ms + OFb - Lfs - Lhs - Hbd" },
        { "id": "eq-96-BLR", "name": "BLR", "desc": "Gross bank liquidity ratio", "expression": "Bbd / Ms" },
        { "id": "eq-97-Rm", "name": "Rm", "desc": "Interest rate on deposits", "expression": "Rm[-1] + z1a * xim1 + z1b * xim2 - z2a * xim1 - z2b * xim2" },
        { "id": "eq-98-z2a", "name": "z2a", "desc": "Is one if bank liquidity ratio is above top range", "expression": "if (BLR[-1] > (top + 0.05)) {1} else {0}" },
        { "id": "eq-99-z2b", "name": "z2b", "desc": "Is one if bank liquidity ratio is above top range", "expression": "if (BLR[-1] > top) {1} else {0}" },
        { "id": "eq-100-z1a", "name": "z1a", "desc": "Is one if bank liquidity ratio is below bottom range", "expression": "if (BLR[-1] <= bot) {1} else {0}" },
        { "id": "eq-101-z1b", "name": "z1b", "desc": "Is one if bank liquidity ratio is below bottom range", "expression": "if (BLR[-1] <= (bot - 0.05)) {1} else {0}" },
        { "id": "eq-102-Rl", "name": "Rl", "desc": "Interest rate on loans", "expression": "Rm + ADDl" },
        { "id": "eq-103-OFbt", "name": "OFbt", "desc": "Long-run target for banks own funds", "expression": "NCAR * (Lfs[-1] + Lhs[-1])" },
        { "id": "eq-104-OFbe", "name": "OFbe", "desc": "Short-run target for banks own funds", "expression": "OFb[-1] + betab * (OFbt - OFb[-1])" },
        { "id": "eq-105-FUbt", "name": "FUbt", "desc": "Targt retained earnings of banks", "expression": "OFbe - OFb[-1] + NPLke * Lfs[-1]" },
        { "id": "eq-106-NPLke", "name": "NPLke", "desc": "Expected proportion of Non-Performing Loans", "expression": "epsb * NPLke[-1] + (1 - epsb) * NPLk[-1]" },
        { "id": "eq-107-FDb", "name": "FDb", "desc": "Dividends of banks", "expression": "Fb - FUb" },
        { "id": "eq-108-Fbt", "name": "Fbt", "desc": "Target profits of banks", "expression": "lambdab * Y[-1] + (OFbe - OFb[-1] + NPLke * Lfs[-1])" },
        { "id": "eq-109-Fb", "name": "Fb", "desc": "Realized banks profits", "expression": "Rl[-1] * (Lfs[-1] + Lhs[-1] - NPL) + Rb[-1] * Bbd[-1] - Rm[-1] * Ms[-1]" },
        { "id": "eq-110-ADDl", "name": "ADDl", "desc": "Spread between interest rate on loans and rate on deposits", "expression": "(Fbt - Rb[-1] * Bbd[-1] + Rm[-1] * (Ms[-1] - (1 - NPLke) * Lfs[-1] - Lhs[-1])) / ((1 - NPLke) * Lfs[-1] + Lhs[-1])" },
        { "id": "eq-111-FUb", "name": "FUb", "desc": "Retained earnings of banks", "expression": "Fb - lambdab * Y[-1]" },
        { "id": "eq-112-OFb", "name": "OFb", "desc": "Own funds of banks", "expression": "OFb[-1] + FUb - NPL" },
        { "id": "eq-113-CAR", "name": "CAR", "desc": "Capital adequacy ratio of banks", "expression": "OFb / (Lfs + Lhs)" },
        { "id": "eq-114-Vf", "name": "Vf", "desc": "", "expression": "IN + K - Lfd - Ekd * Pe" },
        { "id": "eq-115-Ls", "name": "Ls", "desc": "", "expression": "Lfs + Lhs" }
      ],
